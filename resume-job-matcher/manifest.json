{
  "manifest_version": 3,
  "name": "Resume Job Matcher",
  "version": "1.0.0",
  "description": "AI-powered resume analyzer that matches your skills to job roles and highlights skill gaps.",
  "permissions": [],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
